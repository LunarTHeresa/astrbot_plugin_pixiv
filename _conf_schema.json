{
  "pixiv_refresh_token": {
    "description": "Pixiv refresh_token",
    "type": "string",
    "hint": "使用 get_pixiv_token_manual.py 获取后粘贴到这里",
    "obvious_hint": true
  },
  "allow_r18": {
    "description": "是否允许 R18 指令",
    "type": "bool",
    "default": false,
    "hint": "开启后可使用 /pixr 和 /novelr"
  },
  "pixiv_proxy": {
    "description": "Pixiv 代理（可选）",
    "type": "string",
    "default": "",
    "hint": "例如 http://127.0.0.1:7890；服务器无法直连 Pixiv 时填写"
  },
  "request_timeout_sec": {
    "description": "请求超时秒数",
    "type": "int",
    "default": 30,
    "hint": "网络较慢可调大，例如 60"
  }
}
